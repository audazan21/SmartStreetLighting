attr runnumber 21
attr seedset 21
itervar N 5
config image-path ../inet4.4/images
config description "Node count sweep for smart street lighting"
config *.numberOfNodes 5
config *.numberOfGateways 1
config repeat 30
config seed-set 21
config sim-time-limit 1000s
config **.loRaNodes[*].app[0].telemetryBaseTime 120s
config **.loRaNodes[*].app[0].faultMeanTime 600s
config **.loRaNodes[*].app[0].minimumSendGap 20s
config network SmartLoRaNetwork
config sim-time-limit 1000s
config *.numberOfNodes 5
config *.numberOfGateways 1
config **.loRaNodes[*].numApps 1
config **.loRaNodes[*].app[0].typename StreetLightApp
config **.loRaNodes[*].app[0].telemetryBaseTime 120s
config **.loRaNodes[*].app[0].faultMeanTime 600s
config **.loRaNodes[*].app[0].minimumSendGap 20s
config **.loRaNodes[*].app[0].initialLoRaTP 14dBm
config **.loRaNodes[*].app[0].initialLoRaCF 868MHz
config **.loRaNodes[*].app[0].initialLoRaSF 7
config **.loRaNodes[*].app[0].initialLoRaBW 125kHz
config **.loRaNodes[*].app[0].initialLoRaCR 4
config **.loRaNodes[*].app[0].initialUseHeader true
config **.numberOfPacketsToSend 0
config **.timeToFirstPacket exponential(1000s)
config **.timeToNextPacket exponential(1000s)
config **.loRaGW[*].numUdpApps 1
config **.loRaGW[0].packetForwarder.localPort 2000
config **.loRaGW[0].packetForwarder.destPort 1000
config **.loRaGW[0].packetForwarder.destAddresses "\"networkServer\""
config **.loRaGW[0].packetForwarder.indexNumber 0
config **.loRaGW[*].LoRaGWNic.radio.iAmGateway true
config **.networkServer.numApps 1
config **.networkServer.app[0].typename SmartNetworkServerApp
config **.networkServer.app[0].localPort 1000
config **.networkServer.app[0].destAddresses "\"loRaGW[0]\""
config **.networkServer.app[0].destPort 2000
config **.networkServer.app[0].adrMethod "\"avg\""
config **.constraintAreaMinX 0m
config **.constraintAreaMinY 0m
config **.constraintAreaMaxX 1000m
config **.constraintAreaMaxY 1000m
config **.constraintAreaMinZ 0m
config **.constraintAreaMaxZ 0m
config **.loRaNodes[*].**.initialX "uniform(300m, 400m)"
config **.loRaNodes[*].**.initialY "uniform(300m, 400m)"
config **.loRaNodes[*].**.initFromDisplayString false
config **.loRaGW[0].**.initialX 350m
config **.loRaGW[0].**.initialY 350m
config **.loRaGW[*].**.initFromDisplayString false
config **.radio.radioMediumModule "\"LoRaMedium\""
config **.LoRaMedium.pathLossType "\"LoRaLogNormalShadowing\""
config **.energyDetection -110dBm
config **.minInterferenceTime 0s
config **.alohaChannelModel false
config **.vector-recording true
config **.loRaNodes[*].LoRaNic.radio.energyConsumer.typename LoRaEnergyConsumer
config **.loRaNodes[*].LoRaNic.radio.energyConsumer.energySourceModule "\"^.IdealEpEnergyStorage\""
config **.energySourceModule "\"^.IdealEpEnergyStorage\""
config **.loRaNodes[*].LoRaNic.radio.energyConsumer.configFile "xmldoc(\"../flora/simulations/energyConsumptionParameters.xml\")"
config **.internetCloud.ipv4Delayer.config "xmldoc(\"../flora/simulations/cloudDelays.xml\")"
config **.ipv4Delayer.config "xmldoc(\"../flora/simulations/cloudDelays.xml\")"
config **.maxTransmissionDuration 200s

