config network SmartLoRaNetwork
config sim-time-limit 1000s
config *.numberOfNodes 5
config *.numberOfGateways 1
config **.loRaNodes[*].numApps 1
config **.loRaNodes[*].app[0].typename StreetLightApp
config **.loRaNodes[*].app[0].telemetryBaseTime 120s
config **.loRaNodes[*].app[0].faultMeanTime 600s
config **.loRaNodes[*].app[0].minimumSendGap 20s
config **.loRaNodes[*].app[0].initialLoRaTP 14dBm
config **.loRaNodes[*].app[0].initialLoRaCF 868MHz
config **.loRaNodes[*].app[0].initialLoRaSF 7
config **.loRaNodes[*].app[0].initialLoRaBW 125kHz
config **.loRaNodes[*].app[0].initialLoRaCR 4
config **.loRaNodes[*].app[0].initialUseHeader true
config **.numberOfPacketsToSend 0
config **.timeToFirstPacket exponential(1000s)
config **.timeToNextPacket exponential(1000s)
